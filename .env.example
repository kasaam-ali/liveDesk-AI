# =============================================
# LiveDesk AI — Environment Variables
# =============================================
# Copy this file: cp .env.example .env.local
# NEVER commit .env or .env.local to Git!
# =============================================

# --- Groq API (Primary AI Provider) ---
# Get a free key at https://console.groq.com
# Use the key from livedesk-aii/js/brain.js if you have it
NEXT_PUBLIC_GROQ_API_KEY=your_groq_api_key_here
NEXT_PUBLIC_GROQ_MODEL=llama-3.1-8b-instant

# --- Twilio WhatsApp (Web Dev #2) ---
# Create a free account at https://twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AI_ENGINE_URL=http://localhost:3001
NEXT_PUBLIC_BUSINESS_NAME=LiveDesk AI Demo
NEXT_PUBLIC_BUSINESS_TYPE=school
