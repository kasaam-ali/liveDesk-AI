# =============================================
# LiveDesk AI — Environment Variables
# =============================================
# Yeh file copy karo: cp .env.example .env.local
# KABHI BHAI .env.local GitHub pe push mat karo!
# =============================================

# --- Gemini AI (AI Dev #1) ---
# https://aistudio.google.com/app/apikey pe jao — free mein milega
GEMINI_API_KEY=your_gemini_api_key_here

# --- Twilio WhatsApp (Web Dev #2) ---
# https://twilio.com pe free account banao
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BUSINESS_NAME=LiveDesk AI Demo
NEXT_PUBLIC_BUSINESS_TYPE=school
